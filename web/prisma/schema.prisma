generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  image         String?
  emailVerified DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  skills        Skill[]
  accounts      Account[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Skill {
  id          String   @id @default(cuid())
  name        String   @unique
  owner       String
  repo        String
  description String
  installs    Int      @default(0)
  trending24h Int      @default(0)
  category    String
  tags        String[]
  contentPath  String?
  authorName   String?
  telegramLink String?
  featured     Boolean  @default(false)
  status       String   @default("pending")
  githubStars  Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  authorId     String?
  author       User?    @relation(fields: [authorId], references: [id])

  audits       Audit[]

  @@index([category])
  @@index([installs])
}

model Audit {
  id        String   @id @default(cuid())
  skillId   String
  checkName String
  status    String   @default("pending")
  details   String?
  createdAt DateTime @default(now())
  skill     Skill    @relation(fields: [skillId], references: [id], onDelete: Cascade)

  @@unique([skillId, checkName])
  @@index([skillId])
}
